<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
      Per-document encryption key id (key rotation). Nullable — plaintext docs and legacy ("default" key)
      docs leave it null. Postgres-only; H2 tests regenerate from the entity. Idempotent via columnExists.
    -->
    <changeSet id="kyc-003-encryption-key-id" author="truholdem" dbms="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not><columnExists tableName="kyc_documents" columnName="encryption_key_id"/></not>
        </preConditions>
        <addColumn tableName="kyc_documents">
            <column name="encryption_key_id" type="varchar(64)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
