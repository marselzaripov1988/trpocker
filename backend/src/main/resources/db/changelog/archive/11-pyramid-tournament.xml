<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="11-pyramid-tournament-columns" author="truholdem">
        <addColumn tableName="tournaments">
            <column name="pyramid_round" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="hands_per_round" type="INT" defaultValueNumeric="3">
                <constraints nullable="false"/>
            </column>
            <column name="seats_per_table" type="INT" defaultValueNumeric="10">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
