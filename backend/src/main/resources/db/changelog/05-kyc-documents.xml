<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
      KYC verification document metadata (the video bytes live on disk under app.payments.kyc-storage-dir;
      only metadata is in the DB). Hibernate-generated DDL via sqlFile, Postgres-only — H2 tests regenerate
      from the entity. Idempotent via the tableExists precondition.
    -->
    <changeSet id="kyc-001-documents" author="truholdem" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="kyc_documents"/></not>
        </preConditions>
        <sqlFile path="db/changelog/baseline/kyc-documents-postgres.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

</databaseChangeLog>
