<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
      Tournament house commission: a configurable fee (0–20%) on the crypto prize pool. Postgres-only; H2 tests
      regenerate from the entities. Adds the rate columns to tournaments + pyramid_federations and the
      house-revenue ledger (tournament_fee_entries, one idempotent row per paid-out pool). All defaulted to 0,
      so existing rows are unaffected.
    -->

    <changeSet id="tournament-fee-001-tournament-rate" author="truholdem" dbms="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not><columnExists tableName="tournaments" columnName="fee_basis_points"/></not>
        </preConditions>
        <addColumn tableName="tournaments">
            <column name="fee_basis_points" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="tournament-fee-002-federation-rate" author="truholdem" dbms="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not><columnExists tableName="pyramid_federations" columnName="fee_basis_points"/></not>
        </preConditions>
        <addColumn tableName="pyramid_federations">
            <column name="fee_basis_points" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="tournament-fee-003-entries" author="truholdem" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="tournament_fee_entries"/></not>
        </preConditions>
        <createTable tableName="tournament_fee_entries">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_type" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="source_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="asset" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="gross_amount" type="numeric(38, 18)">
                <constraints nullable="false"/>
            </column>
            <column name="fee_amount" type="numeric(38, 18)">
                <constraints nullable="false"/>
            </column>
            <column name="fee_basis_points" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="idempotency_key" type="varchar(128)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_tournament_fee_idempotency"/>
            </column>
            <column name="collected_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="tournament_fee_entries" indexName="idx_tournament_fee_source">
            <column name="source_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
