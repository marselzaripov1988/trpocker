<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
      Link a cash table to its current live hand (a `games` row). One live hand per table at a time; null when
      the table is idle. Postgres-only; H2 regenerates from the entity. Idempotent.
    -->
    <changeSet id="cash-004-current-game" author="truholdem" dbms="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not><columnExists tableName="cash_tables" columnName="current_game_id"/></not>
        </preConditions>
        <addColumn tableName="cash_tables">
            <column name="current_game_id" type="uuid"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
