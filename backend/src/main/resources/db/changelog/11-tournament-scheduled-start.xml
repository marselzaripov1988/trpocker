<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
      Optional scheduled auto-start time for a tournament. Nullable (null = manual start). Postgres-only; H2
      tests regenerate from the entity. Idempotent via columnExists.
    -->
    <changeSet id="tournament-002-scheduled-start" author="truholdem" dbms="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not><columnExists tableName="tournaments" columnName="scheduled_start"/></not>
        </preConditions>
        <addColumn tableName="tournaments">
            <column name="scheduled_start" type="timestamp with time zone"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
