<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
      Manual withdrawal approval: review audit columns + widen the status CHECK to allow PENDING_APPROVAL
      and REJECTED (the baseline generated it with only APPROVED/BROADCAST/CONFIRMED/FAILED). Postgres-only
      (H2 tests regenerate the schema from the entity enum). Idempotent via the columnExists precondition.
    -->
    <changeSet id="withdrawal-001-approval" author="truholdem" dbms="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not><columnExists tableName="withdrawal_requests" columnName="reviewed_by"/></not>
        </preConditions>
        <addColumn tableName="withdrawal_requests">
            <column name="reviewed_by" type="uuid"/>
            <column name="reviewed_at" type="timestamp(6) with time zone"/>
            <column name="rejection_reason" type="varchar(512)"/>
        </addColumn>
        <sql>
            ALTER TABLE withdrawal_requests DROP CONSTRAINT IF EXISTS withdrawal_requests_status_check;
            ALTER TABLE withdrawal_requests ADD CONSTRAINT withdrawal_requests_status_check
                CHECK (status IN ('PENDING_APPROVAL', 'APPROVED', 'BROADCAST',
                                  'CONFIRMED', 'FAILED', 'REJECTED'));
        </sql>
    </changeSet>

</databaseChangeLog>
