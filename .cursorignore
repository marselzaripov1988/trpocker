# Build & dependencies (large, rarely needed for edits)
**/node_modules/
**/target/
**/dist/
**/build/
**/.angular/
**/coverage/
**/.nyc_output/
**/out/
**/out-tsc/

# Lock files (huge, low signal for code changes)
package-lock.json
**/package-lock.json
yarn.lock
**/yarn.lock

# Logs & test artifacts
**/*.log
**/logs/
**/test-results/
**/cypress/videos/
**/cypress/screenshots/
**/playwright-report/

# IDE & OS noise
**/.idea/
**/*.iml
**/.DS_Store
**/.cache/

# Compiled / generated
**/*.class
**/*.jar
**/*.tsbuildinfo

# Secrets (never index)
**/.env
**/.env.*
**/*.pem
**/*.key
**/secrets/
