{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TruHoldem",
  "version": "2.0.0",
  "identifier": "com.truholdem.app",
  "build": {
    "frontendDist": "../dist/texas-holdem-frontend",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "npm run build:native"
  },
  "app": {
    "windows": [
      {
        "title": "TruHoldem",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
