# ---------------------------------------------------------------------------
# Production env template for docker-compose.pyramid-prod.yml
#
#   cp .env.prod.example .env.prod   # then fill in the values below
#   docker compose -f docker-compose.pyramid-prod.yml --env-file .env.prod up -d ...
#
# .env.prod holds real secrets and is git-ignored — NEVER commit it. Keep it
# only on the host (chmod 600). This .example file is the documented template.
# ---------------------------------------------------------------------------

# --- Public hostname & TLS (Let's Encrypt) ------------------------------------
# A real DNS record for PUBLIC_HOST must point at this host, with ports 80+443 open.
# 80 is used for the ACME HTTP-01 challenge and the HTTP→HTTPS redirect.
PUBLIC_HOST=poker.example.com
ACME_EMAIL=ops@example.com

# --- Secrets (REQUIRED) -------------------------------------------------------
# Generate a strong JWT secret:  openssl rand -base64 48
# The backend fail-fasts on startup if JWT_SECRET is unset/weak in a prod profile.
JWT_SECRET=
# Postgres password (used by postgres, pgbouncer and the backend datasource).
DB_PASSWORD=

# --- CORS / WebSocket origins -------------------------------------------------
# Default in the compose file is https://${PUBLIC_HOST}; override only if the SPA
# is served from a different origin (e.g. a separate web domain or a CDN).
# CORS_ORIGINS=https://poker.example.com
# WEBSOCKET_ORIGINS=https://poker.example.com

# --- Images (OPTIONAL: pull instead of build) ---------------------------------
# Leave unset for a build-on-host deploy (compose builds ./backend and ./frontend).
# The CI deploy sets these to the pushed GHCR tags so the host just pulls:
#   BACKEND_IMAGE=ghcr.io/<owner>/truholdem-backend:1.2.3
#   FRONTEND_IMAGE=ghcr.io/<owner>/truholdem-frontend:1.2.3
# BACKEND_IMAGE=
# FRONTEND_IMAGE=

# --- Notes --------------------------------------------------------------------
# * Engine: app.game.engine ships as `aggregate` (production default) — no override needed.
# * Wallet / e-mail / SMS coordinators are flag-gated OFF by default; enable per
#   their own env only when their providers + secrets are configured.
# * Observability (Prometheus/Alertmanager) is the `observability` compose profile:
#       docker compose -f docker-compose.pyramid-prod.yml --env-file .env.prod --profile observability up -d
